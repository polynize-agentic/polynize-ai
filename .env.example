# Supabase (new v2 project — Marrs to provide)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# LLM provider — OpenAI gpt-4o by default for Phase C chat.
# Override LLM_PROVIDER=minimax to fall back to OpenRouter/Minimax.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Minimax via OpenRouter (kept available as a fallback)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-01
OPENROUTER_REFERER=https://polynize.ai
OPENROUTER_TITLE=Polynize Agent Builder

# Resend (gated until DNS is set up)
RESEND_ENABLED=false
RESEND_API_KEY=
RESEND_FROM=blueprints@polynize.ai

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SESSION_COOKIE_NAME=polynize_session
SESSION_COOKIE_MAX_AGE_DAYS=30

# Pricing version stamp on each blueprint
PRICING_VERSION=v1.0-baseline-2026-04
