# Supabase (new v2 project — Marrs to provide)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# LLM provider — Kimi (Moonshot) by default. Switch via LLM_PROVIDER:
#   kimi (default), openai, minimax|openrouter
LLM_PROVIDER=kimi

# Kimi / Moonshot
# Get a key at https://platform.moonshot.cn (CN) or https://platform.moonshot.ai (intl).
# Default model is moonshot-v1-128k. Set KIMI_MODEL=kimi-k2-0905-preview (or
# kimi-latest) to use the newer K2 lineup.
# KIMI_BASE_URL overrides the endpoint, default https://api.moonshot.cn/v1/chat/completions.
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-128k
KIMI_BASE_URL=https://api.moonshot.cn/v1/chat/completions

# OpenAI (kept available as a fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Minimax via OpenRouter (kept available as a fallback)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-01
OPENROUTER_REFERER=https://polynize.ai
OPENROUTER_TITLE=Polynize Agent Builder

# Console auth — magic link via Resend
# CONSOLE_ALLOWED_EMAILS: Polynize team. See all clients.
# CONSOLE_CLIENT_EMAILS:  Per-client access. Format `email:slug,email:slug,...`
#   Each email is scoped to one client slug; signing in redirects them
#   directly to /console/{slug}/blueprint and 404s every other slug.
#   If an email appears in both lists, team scope wins.
POLYNIZE_AUTH_SECRET=
CONSOLE_ALLOWED_EMAILS=marrs@polynize.io,shourov@polynize.io,julian@polynize.io
CONSOLE_CLIENT_EMAILS=
RESEND_ENABLED=true
RESEND_API_KEY=
RESEND_FROM=console@polynize.io

# GitHub App — for Console to read client engagement repos
# GITHUB_APP_PRIVATE_KEY holds multi-line PEM content; when pasting into
# Vercel, either preserve actual newlines or use literal \n sequences (the
# loader normalises both forms before passing to Octokit).
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=

# Console agent API key — for the PAM agent to read/write Console state programmatically
# Optional in v1. When set, the PAM agent can authenticate by sending Authorization: Bearer <this value>
CONSOLE_AGENT_API_KEY=

# Scout webhook — when a blueprint is created we POST a payload to Scout's
# endpoint and he handles the actual email send from his polynize.ai address.
# Leave SCOUT_WEBHOOK_URL empty to silently skip dispatch (status logged as
# 'scout_skipped' in email_log). Optional bearer secret on Authorization.
SCOUT_WEBHOOK_URL=
SCOUT_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SESSION_COOKIE_NAME=polynize_session
SESSION_COOKIE_MAX_AGE_DAYS=30

# Pricing version stamp on each blueprint
PRICING_VERSION=v1.0-baseline-2026-04

# Soft password gate for /proposals (the index of active client decks +
# proposals). Defaults to 'Agentic444' if unset. Override per-environment
# in Vercel project settings to rotate without a redeploy.
PROPOSALS_PASSWORD=
