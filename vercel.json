{
  "rewrites": [
    {
      "source": "/agents",
      "destination": "/agents.html"
    },
    {
      "source": "/pricing",
      "destination": "/pricing.html"
    },
    {
      "source": "/links",
      "destination": "/links.html"
    },
    {
      "source": "/console",
      "destination": "/console.html"
    },
    {
      "source": "/brand",
      "destination": "/brand.html"
    },
    {
      "source": "/proposals/:slug",
      "destination": "/proposals/:slug.html"
    }
  ],
  "headers": [
    {
      "source": "/proposals/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
